              a.each-project-how-to-stake-button(href=project.how_to_stake_url target='_blank')= __('How to Stake?')
              //- .each-project-will-be-stakable-button= __('Coming Soon')
      .calculator-wrapper
        .calculator-title= __('CALCULATOR')
        .calculator-subtitle= __('Calculate how much you will gain with node101.')
        .calculator-projects-wrapper
          each project, i in projects
            .calculator-each-project-title(id='calculator-' + project._id class=(i == 0 ? 'calculator-each-project-title-selected' : ''))= project.name.toUpperCase()
        .calculator-each-line-wrapper#token-calculator-line
          .calculator-each-line-name= projects[0].name.toUpperCase()
          .calculator-each-line
            .calculator-each-line-button(style='margin-left: 10%')
              input.calculator-each-line-button-text#token-calculator-info-text(style='display: none;' type='number' value='10000')
          .calculator-each-line-ammount 10.000
        .calculator-each-line-wrapper#time-calculator-line
          .calculator-each-line-name= __('TIME')
          .calculator-each-line
            .calculator-each-line-button(style='margin-left: 33.33%')
              input.calculator-each-line-button-text#time-calculator-info-text(style='display: none;' type='number' value='30')
          .calculator-each-line-ammount 30 #{__('DAY')}
        .calculator-earn-title= __('YOUR GAIN')
        .calculator-earn-wrapper
          .calculator-each-earn-item
            img.calculator-each-earn-item-icon#calculator-earn-token-icon(src=projects[0].image alt=(projects[0].name + __(' stake')))
            .calculator-each-earn-item-text#calculator-earn-token-text= Math.round((50000 * 27 / 365 * parseFloat(projects[0].apr)))
          .calculator-each-earn-item
            .calculator-each-earn-item-icon $
            .calculator-each-earn-item-text#calculator-earn-dollars-text= Math.round((50000 * 27 / 365 * parseFloat(projects[0].apr)) * projects[0].market_price)
        .calculator-text= __('The amount you will be awarded is calculated using daily interest. Your actual gain may vary slightly from the numbers shown here. Please feel free to contact our team to learn more.')
      .how-to-stake-wrapper
        .how-to-stake-subtitle= __('HOW CAN YOU')
        .how-to-stake-title= __('STAKE A PROJECT?')
        .how-to-stake-text= __('It is quite easy and very profitable with node101 to stake on projects you choose and have a passive-income. Just follow the three simple steps below!')
        .how-to-stake-steps-wrapper
          .each-how-to-stake-step
            .each-how-to-stake-icon-wrapper
              img.each-how-to-stake-icon(src='/res/images/step_icons/search_and_decide.png' alt=__('How to stake with node101? Search and Decide icon.'))
            .each-how-to-stake-title.color-one= __('SEARCH & DECIDE')
            .each-how-to-stake-text= __('See the projects in which we have a validator and choose which projects you want to start with.')
          .each-how-to-stake-step
            .each-how-to-stake-icon-wrapper
              img.each-how-to-stake-icon(src='/res/images/step_icons/stake_your_coin.png' alt=__('How to stake with node101? Stake your Coin icon.'))
            .each-how-to-stake-title.color-two= __('STAKE YOUR COIN')
            .each-how-to-stake-text= __('Click \'How to Stake?\' link below the project you choose to learn how you should stake.')
          .each-how-to-stake-step
            .each-how-to-stake-icon-wrapper
              img.each-how-to-stake-icon(src='/res/images/step_icons/earn_regularly.png' alt=__('How to stake with node101? Earn regularly icon.'))
            .each-how-to-stake-title.color-three= __('EARN REGULARY')
            .each-how-to-stake-text= __('Now all you have to do is to wait and see how your capital grows day by day. It is a true passive income!')
        .how-to-stake-time-text= __('The best options in some projects may require you to lock your coins for a minimum time period. Please feel free to contact our team to learn more.')
      .about-us-wrapper
        .about-us-title= __('ABOUT US')
        .about-us-subtitle= __('node101 describes promising projects in the blockchain ecosystem in a pure language. In addition, it offers a service to users with products that provide financial returns such as node, testnet, staking, and validation.')
        .about-us-text= __('The node101 team, consisting of a group of young software developers and content producers graduated from the world\'s leading schools such as the University of Michigan, Ludwig-Maximillian, University of Sorbonne, and Bogazici University, provides solutions to the accessibility and scalability problems in the industry.')
        .about-us-social-media-wrapper
          a.about-us-each-social-media-icon(href='https://t.me/node101' target='_blank') 
