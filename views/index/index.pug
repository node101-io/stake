      .start-page-wrapper
        .start-page-title
          .start-page-title-text= __('STAKE YOUR ASSETS')
        .start-page-text= __('Stake your assets with the industry\'s most user-friendly organization! node101 accompanies you on your staking journey from start to finish and offers a privileged service where you can safely stake your assets and get support from experts whenever you want.')
        .start-page-learn-more-button= __('Learn More')
      .start-page-transparent-cover
      .projects-wrapper
        .projects-title= __('OUR PROJECTS')
        .projects-subtitle= __('You may stake on us on the following projects. We will be holding validators for you in other networks in the near future.')
        .projects-text= __('Please feel free to reach us in our social media accounts if you have any questions.')
        .projects-inner-wrapper
          each project in projects
            .each-project-wrapper
              .each-project-image(style='background-image: url(' + project.image + ')' )
              .each-project-name= project.name.toUpperCase()
              .each-project-apr APR ~#{parseInt(project.apr * 10000) / 100}%
              a.each-project-stake-button(href=project.stake_url target='_blank')
